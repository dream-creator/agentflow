# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
test-results/
playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.vercel

# sensitive / internal docs
ARCHITECTURE.md
TEST_RELEASE_NOTES.txt
SECURITY-AUDIT.md

# env examples (do not commit)
.env.local.example

# internal docs (do not commit)
OAUTH-CONFIG-GUIDE.md
ROADMAP-REMAINING.md
AGENTS.md

# Supabase config (contains secrets)
supabase/config.toml

# Supabase CLI temp files
supabase/.temp/
.env*

# scripts (local dev tools, not part of app)
scripts/

# Python
__pycache__/

# Hallmark design skill
.impeccable/

# Local dev skills (personal tools, not part of app)
.opencode/skills/

# Design system docs (local only)
DESIGN.md
PRODUCT.md

# Supabase branches
supabase/.branches/

# vercel env pull output (no --file argument defaults to bare filename
# in cwd; commonly written as `production` or `preview` next to .env.local).
# These contain real service-role / anon keys and MUST NEVER be committed.
/production
/preview
/development
vercel-env-*.env
*.vercel.env
